<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.4; padding: 20px; }
    .document { max-width: 8in; margin: 0 auto; }
    
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 3px solid #1a365d; }
    .company-info { flex: 1; }
    .company-name { font-size: 22px; font-weight: 700; color: #1a365d; margin-bottom: 3px; }
    .company-details { font-size: 9px; color: #555; line-height: 1.5; }
    .doc-title-block { text-align: right; }
    .doc-title { font-size: 22px; font-weight: 700; color: #1a365d; letter-spacing: 1px; }
    .doc-subtitle { font-size: 11px; color: #718096; }
    .doc-number { font-size: 14px; color: #e53e3e; font-weight: 600; margin-top: 3px; }
    
    .info-grid { display: flex; gap: 20px; margin-bottom: 20px; }
    .info-box { flex: 1; border: 1px solid #e2e8f0; border-radius: 4px; padding: 12px; }
    .info-box-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 8px; letter-spacing: 0.5px; }
    .info-row { display: flex; margin-bottom: 4px; }
    .info-label { font-weight: 600; color: #4a5568; min-width: 90px; font-size: 10px; }
    .info-value { color: #1a202c; font-size: 10px; }
    
    .confirmation-banner { background: #ebf8ff; border: 1px solid #90cdf4; border-radius: 4px; padding: 12px; margin-bottom: 20px; text-align: center; }
    .confirmation-banner p { font-size: 11px; color: #2a4365; }
    .confirmation-banner strong { color: #1a365d; }
    
    .lines-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .lines-table thead { background: #1a365d; }
    .lines-table th { color: white; padding: 8px 6px; text-align: left; font-size: 9px; font-weight: 600; text-transform: uppercase; }
    .lines-table th.right { text-align: right; }
    .lines-table th.center { text-align: center; }
    .lines-table td { padding: 7px 6px; border-bottom: 1px solid #e2e8f0; font-size: 10px; }
    .lines-table td.right { text-align: right; }
    .lines-table td.center { text-align: center; }
    .lines-table tbody tr:nth-child(even) { background: #f7fafc; }
    .item-specs { font-size: 8px; color: #718096; margin-top: 2px; }
    
    .totals-section { display: flex; justify-content: flex-end; margin-bottom: 20px; }
    .totals-box { width: 250px; }
    .totals-row { display: flex; justify-content: space-between; padding: 5px 10px; font-size: 10px; }
    .totals-row.total { border-top: 2px solid #1a365d; font-weight: 700; font-size: 13px; color: #1a365d; padding-top: 8px; margin-top: 5px; }
    
    .notes-section { margin-bottom: 15px; padding: 10px; background: #f7fafc; border-radius: 4px; border-left: 3px solid #1a365d; }
    .notes-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 5px; }
    .notes-text { font-size: 10px; color: #4a5568; }
    
    .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; }
    .footer-left { font-size: 8px; color: #a0aec0; }
    .footer-right { font-size: 8px; color: #a0aec0; }
  </style>
</head>
<body>
  <div class="document">
    <div class="header">
      <div class="company-info">
        <div class="company-name">{{company.name}}</div>
        <div class="company-details">
          {{company.address}}<br>
          {{company.city}}, {{company.state}} {{company.zip}}<br>
          Phone: {{company.phone}}<br>
          {{#if company.website}}{{company.website}}{{/if}}
        </div>
      </div>
      <div class="doc-title-block">
        <div class="doc-title">ORDER CONFIRMATION</div>
        <div class="doc-subtitle">Sales Order</div>
        <div class="doc-number">{{order_number}}</div>
      </div>
    </div>

    <div class="confirmation-banner">
      <p>Thank you for your order! This confirms that order <strong>{{order_number}}</strong> has been received and is being processed.</p>
    </div>

    <div class="info-grid">
      <div class="info-box">
        <div class="info-box-title">Customer</div>
        <div class="info-row"><div class="info-value" style="font-weight:600; font-size:12px;">{{customer_name}}</div></div>
        {{#if customer_contact}}<div class="info-row"><div class="info-label">Contact:</div><div class="info-value">{{customer_contact}}</div></div>{{/if}}
        {{#if customer_address}}<div class="info-row"><div class="info-label">Bill To:</div><div class="info-value">{{customer_address}}</div></div>{{/if}}
        <div class="info-row"><div class="info-label"></div><div class="info-value">{{customer_city}}, {{customer_state}} {{customer_zip}}</div></div>
      </div>
      <div class="info-box">
        <div class="info-box-title">Ship To</div>
        {{#if ship_address}}<div class="info-row"><div class="info-value">{{ship_address}}</div></div>{{/if}}
        <div class="info-row"><div class="info-value">{{ship_city}}, {{ship_state}} {{ship_zip}}</div></div>
      </div>
      <div class="info-box">
        <div class="info-box-title">Order Details</div>
        <div class="info-row"><div class="info-label">Order Date:</div><div class="info-value">{{formatDate order_date}}</div></div>
        {{#if required_date}}<div class="info-row"><div class="info-label">Required By:</div><div class="info-value">{{formatDate required_date}}</div></div>{{/if}}
        <div class="info-row"><div class="info-label">Terms:</div><div class="info-value">{{or payment_terms "Net 30"}}</div></div>
      </div>
    </div>

    <table class="lines-table">
      <thead>
        <tr>
          <th style="width:30px">#</th>
          <th style="width:80px">Item #</th>
          <th>Description</th>
          <th class="center" style="width:50px">Qty</th>
          <th class="right" style="width:75px">Unit Price</th>
          <th class="right" style="width:85px">Amount</th>
        </tr>
      </thead>
      <tbody>
        {{#each lines}}
        <tr>
          <td>{{line_num}}</td>
          <td><strong>{{item_number}}</strong></td>
          <td>
            {{description}}
            {{#if glass_type}}<div class="item-specs">{{glass_type}} {{#if thickness}}| {{thickness}}mm{{/if}} {{#if width}}| {{width}}x{{height}}{{/if}}</div>{{/if}}
          </td>
          <td class="center">{{quantity}}</td>
          <td class="right">{{formatCurrency unit_price}}</td>
          <td class="right"><strong>{{formatCurrency line_total}}</strong></td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="totals-section">
      <div class="totals-box">
        <div class="totals-row"><span>Subtotal:</span><span>{{formatCurrency subtotal}}</span></div>
        {{#if tax}}<div class="totals-row"><span>Tax:</span><span>{{formatCurrency tax}}</span></div>{{/if}}
        <div class="totals-row total"><span>Order Total:</span><span>{{formatCurrency total}}</span></div>
      </div>
    </div>

    <div class="notes-section">
      <div class="notes-title">What Happens Next</div>
      <div class="notes-text">
        1. Your order will enter production within 1-2 business days.<br>
        2. Estimated lead time: 2-4 weeks depending on specifications.<br>
        3. You will receive a shipment notification with tracking information once your order ships.<br>
        4. An invoice will be sent upon shipment.
      </div>
    </div>

    {{#if notes}}
    <div class="notes-section">
      <div class="notes-title">Order Notes</div>
      <div class="notes-text">{{notes}}</div>
    </div>
    {{/if}}

    <div class="footer">
      <div class="footer-left">{{company.name}} | {{order_number}} | Generated {{today}}</div>
      <div class="footer-right">Page 1 of 1</div>
    </div>
  </div>
</body>
</html>
