<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.4; padding: 20px; }
    .document { max-width: 8in; margin: 0 auto; }
    
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 3px solid #1a365d; }
    .company-info { flex: 1; }
    .company-name { font-size: 22px; font-weight: 700; color: #1a365d; margin-bottom: 3px; }
    .company-details { font-size: 9px; color: #555; line-height: 1.5; }
    .doc-title-block { text-align: right; }
    .doc-title { font-size: 24px; font-weight: 700; color: #1a365d; letter-spacing: 1px; }
    .doc-number { font-size: 14px; color: #e53e3e; font-weight: 600; margin-top: 3px; }
    .doc-status { display: inline-block; padding: 2px 10px; border-radius: 3px; font-size: 9px; font-weight: 600; text-transform: uppercase; margin-top: 5px; }
    .doc-status.posted { background: #c6f6d5; color: #22543d; }
    .doc-status.open { background: #bee3f8; color: #2a4365; }
    .doc-status.paid { background: #c6f6d5; color: #22543d; }
    .doc-status.overdue { background: #fed7d7; color: #742a2a; }
    
    .info-grid { display: flex; gap: 20px; margin-bottom: 20px; }
    .info-box { flex: 1; border: 1px solid #e2e8f0; border-radius: 4px; padding: 12px; }
    .info-box-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 8px; letter-spacing: 0.5px; }
    .info-row { display: flex; margin-bottom: 4px; }
    .info-label { font-weight: 600; color: #4a5568; min-width: 100px; font-size: 10px; }
    .info-value { color: #1a202c; font-size: 10px; }
    
    .lines-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .lines-table thead { background: #1a365d; }
    .lines-table th { color: white; padding: 8px 6px; text-align: left; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }
    .lines-table th.right { text-align: right; }
    .lines-table th.center { text-align: center; }
    .lines-table td { padding: 7px 6px; border-bottom: 1px solid #e2e8f0; font-size: 10px; }
    .lines-table td.right { text-align: right; }
    .lines-table td.center { text-align: center; }
    .lines-table tbody tr:nth-child(even) { background: #f7fafc; }
    
    .totals-section { display: flex; justify-content: flex-end; margin-bottom: 20px; }
    .totals-box { width: 260px; border: 1px solid #e2e8f0; border-radius: 4px; overflow: hidden; }
    .totals-row { display: flex; justify-content: space-between; padding: 6px 12px; font-size: 10px; }
    .totals-row.total { background: #1a365d; color: white; font-weight: 700; font-size: 13px; padding: 10px 12px; }
    .totals-row.balance { background: #e53e3e; color: white; font-weight: 700; font-size: 12px; padding: 8px 12px; }
    
    .payment-info { margin-bottom: 20px; padding: 12px; background: #f0fff4; border-radius: 4px; border: 1px solid #c6f6d5; }
    .payment-info-title { font-size: 10px; font-weight: 700; color: #22543d; margin-bottom: 5px; }
    .payment-info-text { font-size: 10px; color: #2d3748; }
    
    .notes-section { margin-bottom: 15px; padding: 10px; background: #f7fafc; border-radius: 4px; border-left: 3px solid #1a365d; }
    .notes-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 5px; }
    .notes-text { font-size: 10px; color: #4a5568; }
    
    .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; }
    .footer-left { font-size: 8px; color: #a0aec0; }
    .footer-right { font-size: 8px; color: #a0aec0; }
  </style>
</head>
<body>
  <div class="document">
    <div class="header">
      <div class="company-info">
        <div class="company-name">{{company.name}}</div>
        <div class="company-details">
          {{company.address}}<br>
          {{company.city}}, {{company.state}} {{company.zip}}<br>
          Phone: {{company.phone}}<br>
          {{#if company.email}}Email: {{company.email}}<br>{{/if}}
          {{#if company.website}}{{company.website}}{{/if}}
        </div>
      </div>
      <div class="doc-title-block">
        <div class="doc-title">INVOICE</div>
        <div class="doc-number">{{invoice_number}}</div>
        <div class="doc-status {{status}}">{{uppercase status}}</div>
      </div>
    </div>

    <div class="info-grid">
      <div class="info-box">
        <div class="info-box-title">Bill To</div>
        <div class="info-row"><div class="info-value" style="font-weight:600; font-size:12px;">{{customer_name}}</div></div>
        {{#if customer_contact}}<div class="info-row"><div class="info-label">Attn:</div><div class="info-value">{{customer_contact}}</div></div>{{/if}}
        {{#if customer_address}}<div class="info-row"><div class="info-label">Address:</div><div class="info-value">{{customer_address}}</div></div>{{/if}}
        <div class="info-row"><div class="info-label"></div><div class="info-value">{{customer_city}}, {{customer_state}} {{customer_zip}}</div></div>
        {{#if customer_phone}}<div class="info-row"><div class="info-label">Phone:</div><div class="info-value">{{customer_phone}}</div></div>{{/if}}
      </div>
      <div class="info-box">
        <div class="info-box-title">Invoice Details</div>
        <div class="info-row"><div class="info-label">Invoice Date:</div><div class="info-value">{{formatDate invoice_date}}</div></div>
        <div class="info-row"><div class="info-label">Due Date:</div><div class="info-value">{{formatDate due_date}}</div></div>
        <div class="info-row"><div class="info-label">Terms:</div><div class="info-value">{{payment_terms}}</div></div>
        {{#if order_number}}<div class="info-row"><div class="info-label">Order #:</div><div class="info-value">{{order_number}}</div></div>{{/if}}
      </div>
    </div>

    <table class="lines-table">
      <thead>
        <tr>
          <th style="width:30px">#</th>
          <th style="width:90px">Item #</th>
          <th>Description</th>
          <th class="center" style="width:55px">Qty</th>
          <th class="right" style="width:80px">Unit Price</th>
          <th class="right" style="width:90px">Amount</th>
        </tr>
      </thead>
      <tbody>
        {{#each lines}}
        <tr>
          <td>{{line_num}}</td>
          <td><strong>{{item_number}}</strong></td>
          <td>{{description}}</td>
          <td class="center">{{quantity}}</td>
          <td class="right">{{formatCurrency unit_price}}</td>
          <td class="right"><strong>{{formatCurrency line_total}}</strong></td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="totals-section">
      <div class="totals-box">
        <div class="totals-row"><span>Subtotal:</span><span>{{formatCurrency subtotal}}</span></div>
        {{#if tax}}<div class="totals-row"><span>Tax:</span><span>{{formatCurrency tax}}</span></div>{{/if}}
        <div class="totals-row total"><span>Invoice Total:</span><span>{{formatCurrency total}}</span></div>
        {{#if amount_paid}}<div class="totals-row"><span>Amount Paid:</span><span>{{formatCurrency amount_paid}}</span></div>{{/if}}
        <div class="totals-row balance"><span>Balance Due:</span><span>{{formatCurrency balance_due}}</span></div>
      </div>
    </div>

    <div class="payment-info">
      <div class="payment-info-title">Payment Instructions</div>
      <div class="payment-info-text">
        Please make checks payable to: <strong>{{company.name}}</strong><br>
        Reference Invoice # <strong>{{invoice_number}}</strong> with your payment.<br>
        Mail to: {{company.address}}, {{company.city}}, {{company.state}} {{company.zip}}
      </div>
    </div>

    <div class="notes-section">
      <div class="notes-title">Thank You</div>
      <div class="notes-text">Thank you for your business. Please contact us at {{company.phone}} if you have any questions regarding this invoice.</div>
    </div>

    <div class="footer">
      <div class="footer-left">{{company.name}} | {{invoice_number}} | Generated {{today}}</div>
      <div class="footer-right">Page 1 of 1</div>
    </div>
  </div>
</body>
</html>
