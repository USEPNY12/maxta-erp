<!DOCTYPE html>
<html>
<head>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.4; }
  .page { padding: 20px; max-width: 8.5in; }
  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; border-bottom: 3px solid {{company.primary_color}}; padding-bottom: 15px; }
  .company-info { flex: 1; }
  .company-name { font-size: 22px; font-weight: bold; color: {{company.primary_color}}; margin-bottom: 4px; }
  .company-details { font-size: 10px; color: #666; line-height: 1.5; }
  .doc-title { text-align: right; }
  .doc-title h1 { font-size: 24px; color: {{company.primary_color}}; margin-bottom: 5px; }
  .doc-title .meta { font-size: 11px; color: #666; }
  .delivery-info { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px; }
  .info-box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; padding: 12px 15px; }
  .info-box h3 { font-size: 10px; text-transform: uppercase; color: #64748b; margin-bottom: 6px; letter-spacing: 0.5px; }
  table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
  th { background: {{company.primary_color}}; color: white; padding: 8px 10px; text-align: left; font-size: 10px; text-transform: uppercase; }
  td { padding: 7px 10px; border-bottom: 1px solid #e2e8f0; font-size: 10px; }
  tr:nth-child(even) { background: #f8fafc; }
  .amount { text-align: right; }
  .condition-section { margin: 20px 0; padding: 15px; border: 1px solid #e2e8f0; border-radius: 6px; }
  .condition-section h3 { margin-bottom: 10px; font-size: 12px; }
  .condition-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
  .condition-item { text-align: center; padding: 8px; border: 1px solid #e2e8f0; border-radius: 4px; }
  .condition-item label { font-size: 9px; display: block; color: #666; }
  .checkbox { width: 14px; height: 14px; border: 2px solid #333; display: inline-block; margin-top: 3px; }
  .signature-section { margin-top: 30px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
  .sig-block { border: 1px solid #e2e8f0; border-radius: 6px; padding: 15px; }
  .sig-block h4 { font-size: 10px; text-transform: uppercase; color: #64748b; margin-bottom: 10px; }
  .sig-line { border-bottom: 1px solid #333; height: 40px; margin-bottom: 5px; }
  .sig-label { font-size: 9px; color: #666; display: flex; justify-content: space-between; }
  .notes-box { margin-top: 15px; border: 1px solid #e2e8f0; border-radius: 6px; padding: 12px; min-height: 60px; }
  .notes-box h4 { font-size: 10px; color: #64748b; margin-bottom: 5px; }
  .footer { margin-top: 20px; padding-top: 10px; border-top: 1px solid #e2e8f0; font-size: 9px; color: #666; text-align: center; }
</style>
</head>
<body>
<div class="page">
  <div class="header">
    <div class="company-info">
      {{#if company.logo_url}}<img src="{{company.logo_url}}" style="max-height:50px;margin-bottom:5px;">{{/if}}
      <div class="company-name">{{company.name}}</div>
      <div class="company-details">
        {{company.address}}<br>
        {{company.city}}, {{company.state}} {{company.zip}}<br>
        Phone: {{company.phone}}
      </div>
    </div>
    <div class="doc-title">
      <h1>DELIVERY RECEIPT</h1>
      <div class="meta">
        Delivery #: <strong>{{delivery_number}}</strong><br>
        Date: <strong>{{formatDate delivery_date}}</strong><br>
        Order #: <strong>{{order_number}}</strong><br>
        Shipment #: <strong>{{shipment_number}}</strong>
      </div>
    </div>
  </div>

  <div class="delivery-info">
    <div class="info-box">
      <h3>Deliver To</h3>
      <strong>{{customer.company_name}}</strong><br>
      {{#if customer.contact_name}}Attn: {{customer.contact_name}}<br>{{/if}}
      {{delivery_address}}<br>
      {{delivery_city}}, {{delivery_state}} {{delivery_zip}}
    </div>
    <div class="info-box">
      <h3>Delivery Details</h3>
      Driver: <strong>{{driver_name}}</strong><br>
      Vehicle: <strong>{{vehicle}}</strong><br>
      Rack #: <strong>{{rack_number}}</strong><br>
      Route: <strong>{{route_name}}</strong>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Item</th>
        <th>Description</th>
        <th>Dimensions</th>
        <th class="amount">Qty Shipped</th>
        <th class="amount">Qty Received</th>
        <th>Condition</th>
      </tr>
    </thead>
    <tbody>
      {{#each items}}
      <tr>
        <td>{{inc @index}}</td>
        <td>{{this.item_number}}</td>
        <td>{{this.description}}</td>
        <td>{{this.dimensions}}</td>
        <td class="amount">{{this.qty_shipped}}</td>
        <td class="amount">______</td>
        <td>□ Good  □ Damaged</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="condition-section">
    <h3>Delivery Condition</h3>
    <div class="condition-grid">
      <div class="condition-item">
        <div class="checkbox"></div>
        <label>All items received</label>
      </div>
      <div class="condition-item">
        <div class="checkbox"></div>
        <label>Partial delivery</label>
      </div>
      <div class="condition-item">
        <div class="checkbox"></div>
        <label>Damage noted</label>
      </div>
      <div class="condition-item">
        <div class="checkbox"></div>
        <label>Refused delivery</label>
      </div>
    </div>
  </div>

  <div class="notes-box">
    <h4>Delivery Notes / Damage Description</h4>
    <p>&nbsp;</p>
    <p>&nbsp;</p>
  </div>

  <div class="signature-section">
    <div class="sig-block">
      <h4>Received By (Customer)</h4>
      <div class="sig-line"></div>
      <div class="sig-label">
        <span>Print Name</span>
        <span>Date / Time</span>
      </div>
      <div class="sig-line" style="margin-top:15px;"></div>
      <div class="sig-label">
        <span>Signature</span>
      </div>
    </div>
    <div class="sig-block">
      <h4>Delivered By (Driver)</h4>
      <div class="sig-line"></div>
      <div class="sig-label">
        <span>Print Name</span>
        <span>Date / Time</span>
      </div>
      <div class="sig-line" style="margin-top:15px;"></div>
      <div class="sig-label">
        <span>Signature</span>
      </div>
    </div>
  </div>

  <div class="footer">
    By signing above, the receiver acknowledges receipt of the listed items in the condition noted.<br>
    {{company.name}} | {{company.phone}} | {{company.email}}
  </div>
</div>
</body>
</html>
