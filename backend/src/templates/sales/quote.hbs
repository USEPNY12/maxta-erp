<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.4; padding: 20px; }
    .document { max-width: 8in; margin: 0 auto; }
    
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 3px solid #2d5016; }
    .company-info { flex: 1; }
    .company-name { font-size: 22px; font-weight: 700; color: #2d5016; margin-bottom: 3px; }
    .company-details { font-size: 9px; color: #555; line-height: 1.5; }
    .doc-title-block { text-align: right; }
    .doc-title { font-size: 24px; font-weight: 700; color: #2d5016; letter-spacing: 1px; }
    .doc-number { font-size: 14px; color: #c05621; font-weight: 600; margin-top: 3px; }
    .validity { font-size: 9px; color: #718096; margin-top: 5px; padding: 3px 8px; background: #fefcbf; border-radius: 3px; display: inline-block; }
    
    .info-grid { display: flex; gap: 20px; margin-bottom: 20px; }
    .info-box { flex: 1; border: 1px solid #e2e8f0; border-radius: 4px; padding: 12px; }
    .info-box-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 8px; letter-spacing: 0.5px; }
    .info-row { display: flex; margin-bottom: 4px; }
    .info-label { font-weight: 600; color: #4a5568; min-width: 90px; font-size: 10px; }
    .info-value { color: #1a202c; font-size: 10px; }
    
    .lines-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .lines-table thead { background: #2d5016; }
    .lines-table th { color: white; padding: 8px 6px; text-align: left; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }
    .lines-table th.right { text-align: right; }
    .lines-table th.center { text-align: center; }
    .lines-table td { padding: 7px 6px; border-bottom: 1px solid #e2e8f0; font-size: 10px; }
    .lines-table td.right { text-align: right; }
    .lines-table td.center { text-align: center; }
    .lines-table tbody tr:nth-child(even) { background: #f0fff4; }
    .item-specs { font-size: 8px; color: #718096; margin-top: 2px; }
    
    .totals-section { display: flex; justify-content: flex-end; margin-bottom: 20px; }
    .totals-box { width: 250px; }
    .totals-row { display: flex; justify-content: space-between; padding: 5px 10px; font-size: 10px; }
    .totals-row.total { border-top: 2px solid #2d5016; font-weight: 700; font-size: 13px; color: #2d5016; padding-top: 8px; margin-top: 5px; }
    
    .notes-section { margin-bottom: 15px; padding: 10px; background: #f7fafc; border-radius: 4px; border-left: 3px solid #2d5016; }
    .notes-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 5px; }
    .notes-text { font-size: 10px; color: #4a5568; }
    
    .acceptance-section { margin-top: 25px; padding: 15px; border: 2px solid #2d5016; border-radius: 4px; }
    .acceptance-title { font-size: 11px; font-weight: 700; color: #2d5016; margin-bottom: 10px; }
    .acceptance-text { font-size: 9px; color: #4a5568; margin-bottom: 15px; }
    .signature-grid { display: flex; gap: 30px; }
    .signature-block { flex: 1; }
    .signature-line { border-bottom: 1px solid #333; margin-top: 30px; margin-bottom: 5px; }
    .signature-label { font-size: 9px; color: #718096; }
    
    .footer { margin-top: 25px; padding-top: 15px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; }
    .footer-left { font-size: 8px; color: #a0aec0; }
    .footer-right { font-size: 8px; color: #a0aec0; }
  </style>
</head>
<body>
  <div class="document">
    <div class="header">
      <div class="company-info">
        <div class="company-name">{{company.name}}</div>
        <div class="company-details">
          {{company.address}}<br>
          {{company.city}}, {{company.state}} {{company.zip}}<br>
          Phone: {{company.phone}}<br>
          {{#if company.website}}{{company.website}}{{/if}}
        </div>
      </div>
      <div class="doc-title-block">
        <div class="doc-title">QUOTATION</div>
        <div class="doc-number">{{quote_number}}</div>
        {{#if valid_until}}<div class="validity">Valid until: {{formatDate valid_until}}</div>{{/if}}
      </div>
    </div>

    <div class="info-grid">
      <div class="info-box">
        <div class="info-box-title">Prepared For</div>
        <div class="info-row"><div class="info-value" style="font-weight:600; font-size:12px;">{{customer_name}}</div></div>
        {{#if customer_contact}}<div class="info-row"><div class="info-label">Attn:</div><div class="info-value">{{customer_contact}}</div></div>{{/if}}
        {{#if customer_address}}<div class="info-row"><div class="info-label">Address:</div><div class="info-value">{{customer_address}}</div></div>{{/if}}
        <div class="info-row"><div class="info-label"></div><div class="info-value">{{customer_city}}, {{customer_state}} {{customer_zip}}</div></div>
        {{#if customer_phone}}<div class="info-row"><div class="info-label">Phone:</div><div class="info-value">{{customer_phone}}</div></div>{{/if}}
        {{#if customer_email}}<div class="info-row"><div class="info-label">Email:</div><div class="info-value">{{customer_email}}</div></div>{{/if}}
      </div>
      <div class="info-box">
        <div class="info-box-title">Quote Details</div>
        <div class="info-row"><div class="info-label">Quote Date:</div><div class="info-value">{{formatDate quote_date}}</div></div>
        {{#if valid_until}}<div class="info-row"><div class="info-label">Valid Until:</div><div class="info-value">{{formatDate valid_until}}</div></div>{{/if}}
        {{#if project_name}}<div class="info-row"><div class="info-label">Project:</div><div class="info-value">{{project_name}}</div></div>{{/if}}
        <div class="info-row"><div class="info-label">Prepared By:</div><div class="info-value">{{company.name}}</div></div>
      </div>
    </div>

    <table class="lines-table">
      <thead>
        <tr>
          <th style="width:30px">#</th>
          <th style="width:80px">Item #</th>
          <th>Description</th>
          <th class="center" style="width:70px">Specs</th>
          <th class="center" style="width:50px">Qty</th>
          <th class="right" style="width:75px">Unit Price</th>
          <th class="right" style="width:85px">Amount</th>
        </tr>
      </thead>
      <tbody>
        {{#each lines}}
        <tr>
          <td>{{line_num}}</td>
          <td><strong>{{item_number}}</strong></td>
          <td>
            {{description}}
            {{#if glass_type}}<div class="item-specs">{{glass_type}} {{#if edge_type}}| {{edge_type}} edge{{/if}}</div>{{/if}}
          </td>
          <td class="center">
            {{#if thickness}}{{thickness}}mm{{/if}}
            {{#if width}}<br>{{width}}x{{height}}{{/if}}
          </td>
          <td class="center">{{quantity}}</td>
          <td class="right">{{formatCurrency unit_price}}</td>
          <td class="right"><strong>{{formatCurrency line_total}}</strong></td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="totals-section">
      <div class="totals-box">
        <div class="totals-row"><span>Subtotal:</span><span>{{formatCurrency subtotal}}</span></div>
        {{#if tax}}<div class="totals-row"><span>Tax:</span><span>{{formatCurrency tax}}</span></div>{{/if}}
        <div class="totals-row total"><span>Quote Total:</span><span>{{formatCurrency total}}</span></div>
      </div>
    </div>

    {{#if notes}}
    <div class="notes-section">
      <div class="notes-title">Notes</div>
      <div class="notes-text">{{notes}}</div>
    </div>
    {{/if}}

    <div class="notes-section">
      <div class="notes-title">Terms & Conditions</div>
      <div class="notes-text">
        1. This quote is valid for 30 days from the date above unless otherwise noted.<br>
        2. Lead time: 2-4 weeks from order confirmation, depending on specifications.<br>
        3. Payment terms: Net 30 from invoice date.<br>
        4. All glass products are manufactured to order and non-returnable.<br>
        5. Prices do not include shipping unless otherwise stated.
      </div>
    </div>

    <div class="acceptance-section">
      <div class="acceptance-title">Acceptance</div>
      <div class="acceptance-text">By signing below, you accept this quotation and authorize Max TA Group LLC to proceed with the order as specified above.</div>
      <div class="signature-grid">
        <div class="signature-block">
          <div class="signature-line"></div>
          <div class="signature-label">Customer Signature</div>
        </div>
        <div class="signature-block">
          <div class="signature-line"></div>
          <div class="signature-label">Print Name</div>
        </div>
        <div class="signature-block">
          <div class="signature-line"></div>
          <div class="signature-label">Date</div>
        </div>
      </div>
    </div>

    <div class="footer">
      <div class="footer-left">{{company.name}} | {{quote_number}} | Generated {{today}}</div>
      <div class="footer-right">Page 1 of 1</div>
    </div>
  </div>
</body>
</html>
