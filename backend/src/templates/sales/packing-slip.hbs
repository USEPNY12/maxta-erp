<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.4; padding: 20px; }
    .document { max-width: 8in; margin: 0 auto; }
    
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 3px solid #553c9a; }
    .company-info { flex: 1; }
    .company-name { font-size: 22px; font-weight: 700; color: #553c9a; margin-bottom: 3px; }
    .company-details { font-size: 9px; color: #555; line-height: 1.5; }
    .doc-title-block { text-align: right; }
    .doc-title { font-size: 24px; font-weight: 700; color: #553c9a; letter-spacing: 1px; }
    .doc-number { font-size: 14px; color: #e53e3e; font-weight: 600; margin-top: 3px; }
    
    .info-grid { display: flex; gap: 20px; margin-bottom: 20px; }
    .info-box { flex: 1; border: 1px solid #e2e8f0; border-radius: 4px; padding: 12px; }
    .info-box.ship-to { border: 2px solid #553c9a; background: #faf5ff; }
    .info-box-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 8px; letter-spacing: 0.5px; }
    .info-row { display: flex; margin-bottom: 4px; }
    .info-label { font-weight: 600; color: #4a5568; min-width: 80px; font-size: 10px; }
    .info-value { color: #1a202c; font-size: 10px; }
    
    .lines-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .lines-table thead { background: #553c9a; }
    .lines-table th { color: white; padding: 8px 6px; text-align: left; font-size: 9px; font-weight: 600; text-transform: uppercase; }
    .lines-table th.right { text-align: right; }
    .lines-table th.center { text-align: center; }
    .lines-table td { padding: 8px 6px; border-bottom: 1px solid #e2e8f0; font-size: 10px; }
    .lines-table td.right { text-align: right; }
    .lines-table td.center { text-align: center; }
    .lines-table tbody tr:nth-child(even) { background: #faf5ff; }
    
    .no-pricing-notice { text-align: center; font-size: 9px; color: #718096; font-style: italic; margin-bottom: 15px; }
    
    .handling-section { margin-bottom: 20px; padding: 12px; background: #fff5f5; border: 1px solid #fed7d7; border-radius: 4px; }
    .handling-title { font-size: 10px; font-weight: 700; color: #c53030; margin-bottom: 5px; }
    .handling-text { font-size: 10px; color: #742a2a; }
    
    .checklist { margin-bottom: 20px; }
    .checklist-title { font-size: 10px; font-weight: 700; color: #4a5568; margin-bottom: 8px; }
    .checklist-item { display: flex; align-items: center; margin-bottom: 5px; font-size: 10px; }
    .checkbox { width: 14px; height: 14px; border: 1.5px solid #a0aec0; border-radius: 2px; margin-right: 8px; flex-shrink: 0; }
    
    .signature-section { display: flex; gap: 30px; margin-top: 25px; padding-top: 15px; border-top: 1px solid #e2e8f0; }
    .signature-block { flex: 1; }
    .signature-line { border-bottom: 1px solid #333; margin-top: 35px; margin-bottom: 5px; }
    .signature-label { font-size: 9px; color: #718096; }
    
    .footer { margin-top: 25px; padding-top: 15px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; }
    .footer-left { font-size: 8px; color: #a0aec0; }
    .footer-right { font-size: 8px; color: #a0aec0; }
  </style>
</head>
<body>
  <div class="document">
    <div class="header">
      <div class="company-info">
        <div class="company-name">{{company.name}}</div>
        <div class="company-details">
          {{company.address}}<br>
          {{company.city}}, {{company.state}} {{company.zip}}<br>
          Phone: {{company.phone}}
        </div>
      </div>
      <div class="doc-title-block">
        <div class="doc-title">PACKING SLIP</div>
        <div class="doc-number">{{shipment_number}}</div>
      </div>
    </div>

    <div class="info-grid">
      <div class="info-box ship-to">
        <div class="info-box-title">Ship To</div>
        <div class="info-row"><div class="info-value" style="font-weight:600; font-size:13px;">{{customer_name}}</div></div>
        {{#if customer_contact}}<div class="info-row"><div class="info-value">Attn: {{customer_contact}}</div></div>{{/if}}
        {{#if ship_address}}<div class="info-row"><div class="info-value">{{ship_address}}</div></div>{{/if}}
        <div class="info-row"><div class="info-value">{{ship_city}}, {{ship_state}} {{ship_zip}}</div></div>
        {{#if customer_phone}}<div class="info-row"><div class="info-value">Phone: {{customer_phone}}</div></div>{{/if}}
      </div>
      <div class="info-box">
        <div class="info-box-title">Shipping Details</div>
        <div class="info-row"><div class="info-label">Order #:</div><div class="info-value">{{order_number}}</div></div>
        <div class="info-row"><div class="info-label">Ship Date:</div><div class="info-value">{{formatDate ship_date}}</div></div>
        <div class="info-row"><div class="info-label">Carrier:</div><div class="info-value">{{carrier}}</div></div>
        {{#if tracking_number}}<div class="info-row"><div class="info-label">Tracking #:</div><div class="info-value">{{tracking_number}}</div></div>{{/if}}
        {{#if weight}}<div class="info-row"><div class="info-label">Weight:</div><div class="info-value">{{weight}} lbs</div></div>{{/if}}
        {{#if packages}}<div class="info-row"><div class="info-label">Packages:</div><div class="info-value">{{packages}}</div></div>{{/if}}
      </div>
    </div>

    <div class="no-pricing-notice">This document does not include pricing information.</div>

    <table class="lines-table">
      <thead>
        <tr>
          <th style="width:30px">#</th>
          <th style="width:100px">Item #</th>
          <th>Description</th>
          <th class="center" style="width:80px">Qty Ordered</th>
          <th class="center" style="width:80px">Qty Shipped</th>
          <th class="center" style="width:60px">Check</th>
        </tr>
      </thead>
      <tbody>
        {{#each lines}}
        <tr>
          <td>{{line_num}}</td>
          <td><strong>{{item_number}}</strong></td>
          <td>{{description}}</td>
          <td class="center">{{quantity_ordered}}</td>
          <td class="center"><strong>{{quantity_shipped}}</strong></td>
          <td class="center">&#9744;</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="handling-section">
      <div class="handling-title">&#9888; Glass Handling Instructions</div>
      <div class="handling-text">
        FRAGILE - Handle with care. Store upright on edge. Do not lay flat or stack without separators. 
        Inspect all pieces upon delivery. Report any damage to carrier immediately.
      </div>
    </div>

    <div class="checklist">
      <div class="checklist-title">Receiving Checklist:</div>
      <div class="checklist-item"><div class="checkbox"></div>All items received and counted</div>
      <div class="checklist-item"><div class="checkbox"></div>No visible damage to packaging</div>
      <div class="checklist-item"><div class="checkbox"></div>No visible damage to glass</div>
      <div class="checklist-item"><div class="checkbox"></div>Dimensions spot-checked</div>
    </div>

    <div class="signature-section">
      <div class="signature-block">
        <div class="signature-line"></div>
        <div class="signature-label">Packed By</div>
      </div>
      <div class="signature-block">
        <div class="signature-line"></div>
        <div class="signature-label">Received By</div>
      </div>
      <div class="signature-block">
        <div class="signature-line"></div>
        <div class="signature-label">Date Received</div>
      </div>
    </div>

    <div class="footer">
      <div class="footer-left">{{company.name}} | {{shipment_number}} | Order: {{order_number}}</div>
      <div class="footer-right">Generated {{today}}</div>
    </div>
  </div>
</body>
</html>
