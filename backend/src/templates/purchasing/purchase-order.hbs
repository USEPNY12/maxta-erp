<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.4; padding: 20px; }
    .document { max-width: 8in; margin: 0 auto; }
    
    /* Header */
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; padding-bottom: 15px; border-bottom: 3px solid #1a365d; }
    .company-info { flex: 1; }
    .company-name { font-size: 22px; font-weight: 700; color: #1a365d; margin-bottom: 3px; }
    .company-details { font-size: 9px; color: #555; line-height: 1.5; }
    .doc-title-block { text-align: right; }
    .doc-title { font-size: 24px; font-weight: 700; color: #1a365d; letter-spacing: 1px; }
    .doc-number { font-size: 14px; color: #e53e3e; font-weight: 600; margin-top: 3px; }
    .doc-status { display: inline-block; padding: 2px 10px; border-radius: 3px; font-size: 9px; font-weight: 600; text-transform: uppercase; margin-top: 5px; background: #e2e8f0; color: #4a5568; }
    .doc-status.sent { background: #c6f6d5; color: #22543d; }
    .doc-status.draft { background: #fefcbf; color: #744210; }
    .doc-status.approved { background: #bee3f8; color: #2a4365; }
    
    /* Info Grid */
    .info-grid { display: flex; gap: 20px; margin-bottom: 20px; }
    .info-box { flex: 1; border: 1px solid #e2e8f0; border-radius: 4px; padding: 12px; }
    .info-box-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 8px; letter-spacing: 0.5px; }
    .info-row { display: flex; margin-bottom: 4px; }
    .info-label { font-weight: 600; color: #4a5568; min-width: 90px; font-size: 10px; }
    .info-value { color: #1a202c; font-size: 10px; }
    
    /* Table */
    .lines-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .lines-table thead { background: #1a365d; }
    .lines-table th { color: white; padding: 8px 6px; text-align: left; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }
    .lines-table th.right { text-align: right; }
    .lines-table th.center { text-align: center; }
    .lines-table td { padding: 7px 6px; border-bottom: 1px solid #e2e8f0; font-size: 10px; }
    .lines-table td.right { text-align: right; }
    .lines-table td.center { text-align: center; }
    .lines-table tbody tr:nth-child(even) { background: #f7fafc; }
    .lines-table tbody tr:hover { background: #edf2f7; }
    .item-specs { font-size: 8px; color: #718096; margin-top: 2px; }
    
    /* Totals */
    .totals-section { display: flex; justify-content: flex-end; margin-bottom: 20px; }
    .totals-box { width: 250px; }
    .totals-row { display: flex; justify-content: space-between; padding: 5px 10px; font-size: 10px; }
    .totals-row.total { border-top: 2px solid #1a365d; font-weight: 700; font-size: 13px; color: #1a365d; padding-top: 8px; margin-top: 5px; }
    
    /* Notes & Terms */
    .notes-section { margin-bottom: 20px; padding: 12px; background: #f7fafc; border-radius: 4px; border-left: 3px solid #1a365d; }
    .notes-title { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #718096; margin-bottom: 5px; }
    .notes-text { font-size: 10px; color: #4a5568; }
    
    /* Footer */
    .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; }
    .footer-left { font-size: 8px; color: #a0aec0; }
    .footer-right { font-size: 8px; color: #a0aec0; text-align: right; }
    
    /* Signature */
    .signature-section { display: flex; gap: 40px; margin-top: 30px; }
    .signature-block { flex: 1; }
    .signature-line { border-bottom: 1px solid #333; margin-top: 40px; margin-bottom: 5px; }
    .signature-label { font-size: 9px; color: #718096; }
  </style>
</head>
<body>
  <div class="document">
    <!-- Header -->
    <div class="header">
      <div class="company-info">
        <div class="company-name">{{company.name}}</div>
        <div class="company-details">
          {{company.address}}<br>
          {{company.city}}, {{company.state}} {{company.zip}}<br>
          Phone: {{company.phone}}<br>
          {{#if company.email}}Email: {{company.email}}<br>{{/if}}
          {{#if company.website}}{{company.website}}{{/if}}
        </div>
      </div>
      <div class="doc-title-block">
        <div class="doc-title">PURCHASE ORDER</div>
        <div class="doc-number">{{po_number}}</div>
        <div class="doc-status {{status}}">{{uppercase status}}</div>
      </div>
    </div>

    <!-- Info Grid -->
    <div class="info-grid">
      <div class="info-box">
        <div class="info-box-title">Vendor</div>
        <div class="info-row"><div class="info-value" style="font-weight:600; font-size:12px;">{{vendor_name}}</div></div>
        {{#if vendor_contact}}<div class="info-row"><div class="info-label">Contact:</div><div class="info-value">{{vendor_contact}}</div></div>{{/if}}
        {{#if vendor_address}}<div class="info-row"><div class="info-label">Address:</div><div class="info-value">{{vendor_address}}</div></div>{{/if}}
        <div class="info-row"><div class="info-label"></div><div class="info-value">{{vendor_city}}, {{vendor_state}} {{vendor_zip}}</div></div>
        {{#if vendor_phone}}<div class="info-row"><div class="info-label">Phone:</div><div class="info-value">{{vendor_phone}}</div></div>{{/if}}
        {{#if vendor_email}}<div class="info-row"><div class="info-label">Email:</div><div class="info-value">{{vendor_email}}</div></div>{{/if}}
      </div>
      <div class="info-box">
        <div class="info-box-title">Order Details</div>
        <div class="info-row"><div class="info-label">PO Date:</div><div class="info-value">{{formatDate order_date}}</div></div>
        <div class="info-row"><div class="info-label">Required By:</div><div class="info-value">{{formatDate required_date}}</div></div>
        <div class="info-row"><div class="info-label">Payment Terms:</div><div class="info-value">{{payment_terms}}</div></div>
        {{#if ship_to}}<div class="info-row"><div class="info-label">Ship To:</div><div class="info-value">{{ship_to}}</div></div>{{/if}}
        <div class="info-row"><div class="info-label">PO Type:</div><div class="info-value">{{or po_type "Standard"}}</div></div>
      </div>
    </div>

    <!-- Line Items Table -->
    <table class="lines-table">
      <thead>
        <tr>
          <th style="width:30px">#</th>
          <th style="width:80px">Item #</th>
          <th style="width:70px">Vendor #</th>
          <th>Description</th>
          <th class="center" style="width:50px">Qty</th>
          <th class="right" style="width:75px">Unit Cost</th>
          <th class="right" style="width:80px">Amount</th>
        </tr>
      </thead>
      <tbody>
        {{#each lines}}
        <tr>
          <td>{{line_num}}</td>
          <td><strong>{{item_number}}</strong></td>
          <td>{{vendor_item_number}}</td>
          <td>
            {{description}}
            {{#if glass_type}}<div class="item-specs">{{glass_type}} {{#if thickness}}| {{thickness}}{{/if}} {{#if width}}| {{width}}x{{height}}{{/if}}</div>{{/if}}
          </td>
          <td class="center">{{quantity}}</td>
          <td class="right">{{formatCurrency unit_cost}}</td>
          <td class="right"><strong>{{formatCurrency line_total}}</strong></td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- Totals -->
    <div class="totals-section">
      <div class="totals-box">
        <div class="totals-row"><span>Subtotal:</span><span>{{formatCurrency subtotal}}</span></div>
        {{#if tax}}<div class="totals-row"><span>Tax:</span><span>{{formatCurrency tax}}</span></div>{{/if}}
        <div class="totals-row total"><span>PO Total:</span><span>{{formatCurrency total}}</span></div>
      </div>
    </div>

    <!-- Notes -->
    {{#if notes}}
    <div class="notes-section">
      <div class="notes-title">Notes / Special Instructions</div>
      <div class="notes-text">{{notes}}</div>
    </div>
    {{/if}}

    <!-- Terms -->
    <div class="notes-section">
      <div class="notes-title">Terms & Conditions</div>
      <div class="notes-text">
        1. Please confirm this order within 2 business days.<br>
        2. All shipments must reference this PO number.<br>
        3. Material must meet specified quality standards.<br>
        4. Packing slips must accompany all shipments.
      </div>
    </div>

    <!-- Signature -->
    <div class="signature-section">
      <div class="signature-block">
        <div class="signature-line"></div>
        <div class="signature-label">Authorized By (Buyer)</div>
      </div>
      <div class="signature-block">
        <div class="signature-line"></div>
        <div class="signature-label">Date</div>
      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      <div class="footer-left">{{company.name}} | {{po_number}} | Generated {{today}}</div>
      <div class="footer-right">Page 1 of 1</div>
    </div>
  </div>
</body>
</html>
